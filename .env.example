# Logging & Debugging
LOG_LEVEL=INFO
# Options: DEBUG, INFO, WARNING, ERROR, CRITICAL

# Pipeline settings
ARTICLES_LIMIT_PER_SOURCE=50
CLASSIFICATION_THRESHOLD=0.75

# Database
DATABASE_PATH=data/upnews.db

# Thumbnail Extraction (TASK 3)
THUMBNAIL_CONCURRENCY=10
THUMBNAIL_TIMEOUT=5
THUMBNAIL_CACHE_ENABLED=true

# LLM Categorization (TASK 4)
CATEGORIZATION_METHOD=zero-shot
# Options: zero-shot, claude-haiku
# CLAUDE_API_KEY=your-key-here (if using claude-haiku)

# Summarization (TASK 5)
SUMMARIZATION_METHOD=distilbart
# Options: distilbart, claude-haiku
# CLAUDE_API_KEY=your-key-here (if using claude-haiku)

# Optional: Redis cache (for TASK 3, 4, 5)
# REDIS_URL=redis://localhost:6379

# Crawler settings
CRAWLER_TIMEOUT=10
CRAWLER_RETRIES=2
USER_AGENT=Mozilla/5.0 (Windows NT 10.0; Win64; x64) AppleWebKit/537.36

# Optional: Monitoring & Alerts
# SLACK_WEBHOOK_URL=https://hooks.slack.com/...
# ALERT_ON_ERROR_RATE=0.05
# ALERT_ON_DURATION_SEC=300
