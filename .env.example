# ─────────────────────────────────────────────────────────────────────────────
# .env.example  –  master reference for all environment variables
#
# DO NOT use this file directly. Copy the right env file for your target:
#   Local dev   →  .env.local  (gitignored, edit freely)
#   Dev deploy  →  .env.dev
#   PR/Staging  →  .env.pr
#   QA          →  .env.qa
#   Production  →  .env.prod
#
# Then run:
#   docker compose --env-file .env.<env> up --build
#   (or use the Makefile:  make local | dev | pr | qa | prod)
# ─────────────────────────────────────────────────────────────────────────────

# --- Environment tag (used by docker-compose image tag) ---
# Values: local | dev | pr | qa | prod
ENV=local

# --- Logging ---
# Options: DEBUG, INFO, WARNING, ERROR, CRITICAL
LOG_LEVEL=INFO

# --- Pipeline limits ---
ARTICLES_LIMIT_PER_SOURCE=50
CLASSIFICATION_THRESHOLD=0.75

# --- Classifier ---
# Options: rules (no model needed), setfit (requires model weights mounted)
CLASSIFIER_MODE=rules

# --- Enrichment: Summarization ---
# Options: none (fastest, leaves summary empty), title (fast placeholder), distilbart (local HuggingFace), claude-haiku (requires CLAUDE_API_KEY)
SUMMARIZATION_METHOD=none

# --- Enrichment: Categorization ---
# Options: topic (bundled SetFit model), zero-shot (downloads BART-MNLI), claude-haiku (requires CLAUDE_API_KEY)
CATEGORIZATION_METHOD=topic

# --- Thumbnails ---
THUMBNAIL_CONCURRENCY=10
THUMBNAIL_TIMEOUT=5
THUMBNAIL_CACHE_ENABLED=true

# --- Crawler ---
CRAWLER_TIMEOUT=10
CRAWLER_RETRIES=2
USER_AGENT=Mozilla/5.0 (Windows NT 10.0; Win64; x64) AppleWebKit/537.36

# --- Database ---
# Inside Docker the path is /app/data/upnews.db (mapped to ./data/ on host)
DATABASE_PATH=/app/data/upnews.db

# --- Optional: Claude API (required for claude-haiku summarization/categorization) ---
# Inject via CI/CD secrets or a secrets manager — never commit a real key.
# CLAUDE_API_KEY=

# --- Optional: Monitoring ---
# SLACK_WEBHOOK_URL=
# ALERT_ON_ERROR_RATE=0.05
# ALERT_ON_DURATION_SEC=300

# --- Optional: Redis cache ---
# REDIS_URL=redis://localhost:6379
