# ─────────────────────────────────────────────────────────────
# DEV environment — shared development / feature branch deploys
# Safe to commit — contains no real secrets.
# Inject CLAUDE_API_KEY via CI/CD secrets if needed.
# ─────────────────────────────────────────────────────────────

# --- Environment tag (used by docker-compose image tag) ---
ENV=dev

# --- Logging ---
LOG_LEVEL=DEBUG

# --- Pipeline limits ---
ARTICLES_LIMIT_PER_SOURCE=25
CLASSIFICATION_THRESHOLD=0.65

# --- Classifier ---
CLASSIFIER_MODE=rules

# --- Enrichment ---
SUMMARIZATION_METHOD=none
CATEGORIZATION_METHOD=topic

# --- Thumbnails ---
THUMBNAIL_CONCURRENCY=10
THUMBNAIL_TIMEOUT=5
THUMBNAIL_CACHE_ENABLED=true

# --- Crawler ---
CRAWLER_TIMEOUT=10
CRAWLER_RETRIES=2
USER_AGENT=Mozilla/5.0 (Windows NT 10.0; Win64; x64) AppleWebKit/537.36

# --- Database ---
DATABASE_PATH=/app/data/upnews.db

# --- Optional: Claude API ---
# CLAUDE_API_KEY injected via CI/CD secret

# --- Optional: Monitoring ---
# SLACK_WEBHOOK_URL injected via CI/CD secret
