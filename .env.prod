# ─────────────────────────────────────────────────────────────
# PRODUCTION environment
# Safe to commit — all sensitive values injected via CI/CD or
# a secrets manager (e.g. GitHub Actions secrets, Doppler).
# ─────────────────────────────────────────────────────────────

# --- Environment tag (used by docker-compose image tag) ---
ENV=prod

# --- Logging ---
LOG_LEVEL=WARNING

# --- Pipeline limits ---
ARTICLES_LIMIT_PER_SOURCE=100
CLASSIFICATION_THRESHOLD=0.80

# --- Classifier (SetFit requires model weights mounted at /app/models/setfit_uplifting_model/) ---
CLASSIFIER_MODE=setfit

# --- Enrichment ---
SUMMARIZATION_METHOD=title
CATEGORIZATION_METHOD=setfit

# --- Thumbnails ---
THUMBNAIL_CONCURRENCY=20
THUMBNAIL_TIMEOUT=10
THUMBNAIL_CACHE_ENABLED=true

# --- Crawler ---
CRAWLER_TIMEOUT=15
CRAWLER_RETRIES=3
USER_AGENT=Mozilla/5.0 (Windows NT 10.0; Win64; x64) AppleWebKit/537.36

# --- Database ---
DATABASE_PATH=/app/data/upnews.db

# --- Optional: Claude API (inject via secrets manager) ---
# CLAUDE_API_KEY=

# --- Optional: Monitoring (inject via secrets manager) ---
# SLACK_WEBHOOK_URL=
# ALERT_ON_ERROR_RATE=0.05
# ALERT_ON_DURATION_SEC=300
