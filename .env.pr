# ─────────────────────────────────────────────────────────────
# PR / STAGING environment — runs on every pull request
# Production-like settings, reduced scale for cost control.
# Safe to commit — inject secrets via CI/CD.
# ─────────────────────────────────────────────────────────────

# --- Environment tag (used by docker-compose image tag) ---
ENV=pr

# --- Logging ---
LOG_LEVEL=INFO

# --- Pipeline limits ---
ARTICLES_LIMIT_PER_SOURCE=50
CLASSIFICATION_THRESHOLD=0.75

# --- Classifier ---
CLASSIFIER_MODE=rules

# --- Enrichment ---
SUMMARIZATION_METHOD=distilbart
CATEGORIZATION_METHOD=zero-shot

# --- Thumbnails ---
THUMBNAIL_CONCURRENCY=10
THUMBNAIL_TIMEOUT=5
THUMBNAIL_CACHE_ENABLED=true

# --- Crawler ---
CRAWLER_TIMEOUT=10
CRAWLER_RETRIES=2
USER_AGENT=Mozilla/5.0 (Windows NT 10.0; Win64; x64) AppleWebKit/537.36

# --- Database ---
DATABASE_PATH=/app/data/upnews.db

# --- Optional: Claude API ---
# CLAUDE_API_KEY injected via CI/CD secret

# --- Optional: Monitoring ---
# SLACK_WEBHOOK_URL injected via CI/CD secret
