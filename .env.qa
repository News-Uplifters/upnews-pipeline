# ─────────────────────────────────────────────────────────────
# QA environment — full-scale test runs before production
# Uses SetFit ML classifier; mirrors prod behaviour.
# Safe to commit — inject secrets via CI/CD.
# ─────────────────────────────────────────────────────────────

# --- Environment tag (used by docker-compose image tag) ---
ENV=qa

# --- Logging ---
LOG_LEVEL=INFO

# --- Pipeline limits ---
ARTICLES_LIMIT_PER_SOURCE=50
CLASSIFICATION_THRESHOLD=0.75

# --- Classifier (SetFit requires model weights mounted at /app/models/setfit_uplifting_model/) ---
CLASSIFIER_MODE=setfit

# --- Enrichment ---
SUMMARIZATION_METHOD=title
CATEGORIZATION_METHOD=setfit

# --- Thumbnails ---
THUMBNAIL_CONCURRENCY=10
THUMBNAIL_TIMEOUT=5
THUMBNAIL_CACHE_ENABLED=true

# --- Crawler ---
CRAWLER_TIMEOUT=15
CRAWLER_RETRIES=3
USER_AGENT=Mozilla/5.0 (Windows NT 10.0; Win64; x64) AppleWebKit/537.36

# --- Database ---
DATABASE_PATH=/app/data/upnews.db

# --- Optional: Claude API ---
# CLAUDE_API_KEY injected via CI/CD secret

# --- Optional: Monitoring ---
# SLACK_WEBHOOK_URL injected via CI/CD secret
# ALERT_ON_ERROR_RATE=0.05
# ALERT_ON_DURATION_SEC=300
